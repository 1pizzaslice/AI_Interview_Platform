# Server
PORT=4000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/ai_interview

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change_me_to_a_long_random_secret
JWT_REFRESH_SECRET=change_me_to_another_long_random_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Providers
LLM_PROVIDER=mock
# LLM_PROVIDER=claude
STT_PROVIDER=mock
TTS_PROVIDER=mock
STORAGE_PROVIDER=local
# STORAGE_PROVIDER=s3

# Anthropic (required when LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=

# AWS S3 (required when STORAGE_PROVIDER=s3)
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=

# File upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# Interview
SESSION_TIMEOUT_SECONDS=900
ANSWER_TIMEOUT_SECONDS=90
ANSWER_FOLLOWUP_TIMEOUT_SECONDS=60
